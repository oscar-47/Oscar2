{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "generate_image_request",
  "type": "object",
  "properties": {
    "model": {
      "type": "string",
      "enum": [
        "azure-flux",
        "gpt-image",
        "qiniu-gemini-pro",
        "qiniu-gemini-flash",
        "volc-seedream-4.5",
        "volc-seedream-5.0-lite",
        "or-gemini-2.5-flash",
        "or-gemini-3.1-flash",
        "or-gemini-3-pro",
        "ta-gemini-2.5-flash",
        "ta-gemini-3.1-flash",
        "ta-gemini-3-pro"
      ],
      "default": "or-gemini-3.1-flash"
    },
    "promptProfile": { "type": "string", "enum": ["default", "ta-pro"], "default": "default" },
    "prompt": { "type": "string" },
    "productImage": { "type": "string" },
    "productImages": { "type": "array", "items": { "type": "string" } },
    "imageCount": { "type": "integer", "minimum": 1, "default": 1 },
    "aspectRatio": { "type": "string", "default": "1:1" },
    "imageSize": { "type": "string", "enum": ["1K", "2K", "4K"], "default": "2K" },
    "turboEnabled": { "type": "boolean", "default": false },
    "workflowMode": { "type": "string", "default": "product" },
    "trace_id": { "type": "string", "format": "uuid" },
    "client_job_id": { "type": "string" },
    "metadata": {
      "type": "object",
      "properties": {
        "is_batch": { "type": "boolean" },
        "batch_index": { "type": "integer", "minimum": 0 },
        "image_size": { "type": "string" },
        "product_images": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "styleConstraint": {
      "type": "object",
      "properties": {
        "selections": { "type": "object", "additionalProperties": { "type": "string" } },
        "prompt": { "type": "string", "maxLength": 600 },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "textEdits": {
      "type": "object",
      "additionalProperties": { "type": "string", "maxLength": 80 }
    }
  },
  "required": ["model", "prompt"],
  "additionalProperties": true
}
