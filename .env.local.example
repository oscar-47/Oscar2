# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# === Frontend / Next.js ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://shopix.ai
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
GOOGLE_SITE_VERIFICATION=

# === Shared app/backend ===
APP_URL=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage provider for get-oss-sts
STORAGE_PROVIDER=supabase_compat
UPLOAD_PUBLIC_HOST=https://cdn.shopix.ai
SOURCE_IMAGE_BASE_URL=https://cdn.shopix.ai
GENERATIONS_BUCKET=generations

# Optional Qiniu upload-sign provider (only if STORAGE_PROVIDER=qiniu)
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=temp
QINIU_UPLOAD_URL=https://up.qiniup.com
QINIU_CDN_HOST=

# === QN image generation API ===
QN_IMAGE_API_KEY=sk-...
QN_IMAGE_API_ENDPOINT=https://api.qnaigc.com/v1/images/edits
QN_IMAGE_MODEL=gemini-3.0-pro-image-preview
AZURE_FLUX_API_KEY=
AZURE_FLUX_API_ENDPOINT=
AZURE_FLUX_MODEL=black-forest-labs/FLUX.1-Kontext-pro
GPT_IMAGE_API_KEY=
GPT_IMAGE_API_ENDPOINT=https://api.openai.com/v1/images/edits
GPT_IMAGE_MODEL=gpt-image-1
QINIU_GEMINI_API_KEY=
QINIU_GEMINI_API_ENDPOINT=https://api.qnaigc.com/v1/images/edits
QN_IMAGE_GEMINI_PRO_MODEL=gemini-3.0-pro-image-preview
QN_IMAGE_FLASH_MODEL=gemini-2.0-flash-preview-image-generation
QN_IMAGE_REQUEST_TIMEOUT_MS=30000

# === Volcengine Doubao (for style replicate when selecting doubao models) ===
DOUBAO_IMAGE_API_KEY=
DOUBAO_IMAGE_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations
DOUBAO_MODEL_45=doubao-seedream-4-5-251128
DOUBAO_MODEL_50_LITE=doubao-seedream-5.0-lite

QN_CHAT_API_KEY=sk-...
QN_CHAT_API_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
QN_CHAT_MODEL=gpt-4o
QN_CHAT_REQUEST_TIMEOUT_MS=30000

# AI (reserved — OpenRouter for analysis/prompts)
OPENROUTER_API_KEY=
GEMINI_API_KEY=
TOAPIS_API_ENDPOINT=https://toapis.com/v1/images/generations
TOAPIS_API_KEY=

# Stripe backend
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
